{
  "version": 2,
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "outputDirectory": "dist/public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/[^.]+$", "dest": "/index.html", "status": 200 },
    { "src": "/(.*)", "headers": { "Cache-Control": "public, max-age=0, must-revalidate" } }
  ]
}

# ===========================================
# StudyOS - Variables de Entorno
# ===========================================
# Copia este archivo a .env y rellena los valores

# ===========================================
# VARIABLES DEL CLIENTE (VITE)
# ===========================================
# Estas variables están disponibles en el navegador
# Prefijo: VITE_

# Groq API (para chat y guiones de podcast)
VITE_GROQ_API_KEY=tu_key_de_groq

# Gemini API (respaldo para chat)
VITE_GEMINI_API_KEY=tu_key_de_gemini

# ===========================================
# VARIABLES DEL SERVIDOR (VERCEL)
# ===========================================
# Estas variables son SOLO para serverless functions
# NO llevan prefijo VITE_
# Configurar en Vercel Dashboard → Settings → Environment Variables

# Token de Hugging Face para TTS
# Obtener en: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_tu_token

# ===========================================
# GOOGLE OAUTH (para Agente IA)
# ===========================================
# Obtener en: https://console.cloud.google.com/apis/credentials
# 1. Crear OAuth 2.0 Client ID
# 2. Añadir URI de redirección: TU_DOMINIO/api/auth/callback

# Client ID (público - va en el cliente)
VITE_GOOGLE_CLIENT_ID=tu_google_client_id

# Client Secret (SECRETO - solo servidor)
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# URI de callback (igual al configurado en Google Console)
VITE_REDIRECT_URI=https://tu-dominio.vercel.app/api/auth/callback
